# Front controller: route every request that is not a real file/dir to index.php
RewriteEngine On

# Allow the Authorization header through to PHP (needed once AUTH_ENABLED=true)
RewriteCond %{HTTP:Authorization} .
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [QSA,L]

# Don't serve the env file or sql/ if someone guesses the path
<FilesMatch "^\.env">
  Require all denied
</FilesMatch>
<FilesMatch "\.(sql|md)$">
  Require all denied
</FilesMatch>
