# Copy to .env on the server and fill in the MySQL credentials you created in
# the Webuzo "Add Database" / "Add Database User" screens.

# Environment
APP_ENV=production

# MySQL (created via the hosting panel — usually prefixed with your cPanel user)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=argusinf_padmavati
DB_USER=argusinf_padmavati
DB_PASS=change_me

# CORS (comma separated origins, or * for all)
CORS_ORIGIN=*

# JWT (prepared for future auth - authentication is currently DISABLED)
JWT_SECRET=change_this_super_secret_key
JWT_EXPIRES_IN=7d

# Feature flags
AUTH_ENABLED=false
