# Server
# Note: macOS uses port 5000 for AirPlay Receiver, so we default to 4000.
PORT=4000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/padmavati_bangles

# CORS (comma separated origins, or * for all)
CORS_ORIGIN=*

# JWT (prepared for future auth - authentication is currently DISABLED)
JWT_SECRET=change_this_super_secret_key
JWT_EXPIRES_IN=7d

# Feature flags
AUTH_ENABLED=false
